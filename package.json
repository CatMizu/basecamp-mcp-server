{
  "name": "basecamp-mcp-server",
  "version": "0.1.0",
  "description": "Remote MCP server for Basecamp 3 with OAuth-wrapping and SQLite-backed token vault",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --inspect src/index.ts",
    "build": "tsc && npm run copy-static",
    "copy-static": "mkdir -p dist/static && cp -r src/static/* dist/static/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev-reset-db": "tsx scripts/dev-reset-db.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.24.2",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "overrides": {
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "5.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}

# Basecamp MCP server — example env file.
# Copy to .env and fill in secrets for local dev. Never commit .env.

PORT=3232
BASE_URI=http://localhost:3232
NODE_ENV=development

# Basecamp OAuth app credentials — register at
# https://launchpad.37signals.com/integrations and set the redirect URI to
# ${BASE_URI}/oauth/basecamp/callback.
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=

# Contact shown in the User-Agent header on every Basecamp API call. Basecamp
# requires a real contact. See https://github.com/basecamp/bc3-api#identification
USER_AGENT_CONTACT=ops@your-domain.example

# SQLite vault location. In prod this points at the Fly volume mount.
VAULT_DB_PATH=./vault.db
